{
  "name": "scripturelm",
  "version": "0.1.0",
  "private": true,
  "description": "NotebookLM-style app (Next.js monolith). Background worker: `npm run worker` (src/worker/index.ts).",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "check-env": "tsx scripts/check-env.ts",
    "register-source": "tsx scripts/register-source.ts",
    "bulk-ingest-markdown": "tsx scripts/bulk-ingest-markdown.ts",
    "ingest:chunk": "tsx scripts/ingest-chunk.ts",
    "download-vgr-pdfs": "tsx scripts/download-vgr-sermon-pdfs.ts",
    "branham-pdfs-to-md": "tsx scripts/branham-pdfs-to-markdown.ts",
    "db:check": "tsx scripts/db-check.ts",
    "db:check:rds": "tsx scripts/db-check.ts --rds",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "worker": "tsx src/worker/index.ts",
    "jobs:enqueue": "tsx scripts/jobs-enqueue.ts",
    "jobs:list": "tsx scripts/jobs-list.ts",
    "retrieve:smoke": "tsx scripts/retrieve-smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1028.0",
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/client-sqs": "^3.1029.0",
    "@prisma/client": "^6.19.0",
    "bcrypt": "^6.0.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.0",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
