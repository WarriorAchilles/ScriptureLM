# Copy to `.env` (gitignored) and adjust values. Never commit real secrets.
#
# Runtime: the app uses a single active URL, `DATABASE_URL`. There is no multi-DB switch in code.
# Convention for optional dev RDS: keep `DATABASE_URL_RDS_DEV` here as a reference, and when you
# want the app and Prisma to hit RDS, copy that value into `DATABASE_URL` in `.env` (or
# maintain two blocks and comment/uncomment). Always confirm the target before destructive migrations.
#
# --- Security ---
# Never put Anthropic keys, AWS secret keys, or operator secrets in `NEXT_PUBLIC_*` variables
# (those are exposed to the browser).

# --- Primary local dev: Docker Compose Postgres (see docker-compose.yml) ---
# Matches default POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in compose unless you changed them.
DATABASE_URL="postgresql://scripturelm:scripturelm_dev_password@localhost:5433/scripturelm?schema=public"

# --- Optional: cloud dev RDS (same schema/migrations; AWS-parity checks) ---
# Uncomment and set when you have a dev RDS instance with pgvector. To use it, copy this URL into
# DATABASE_URL above (or swap commented blocks). Ensure your machine can reach RDS (security group/VPN).
# DATABASE_URL_RDS_DEV="postgresql://USER:PASSWORD@your-dev-rds.region.rds.amazonaws.com:5432/DBNAME?schema=public"

# --- Source blob storage (Step 06) ---
# Where raw corpus files are stored: `filesystem` (local path) or `s3` (AWS / LocalStack / MinIO).
# When unset: filesystem in development, s3 in production builds.
# STORAGE_BACKEND="filesystem"
# Local directory for blobs when using filesystem (create it or use e.g. ./data/sources — see .gitignore).
SOURCE_STORAGE_ROOT="./data/sources"
# Optional: custom S3 API URL for LocalStack or MinIO (only when STORAGE_BACKEND=s3).
# S3_ENDPOINT_URL="http://localhost:4566"

# --- AWS (Bedrock, S3, optional SQS) ---
# Region for Bedrock, S3, and other AWS APIs.
AWS_REGION="us-east-1"
# Bucket for uploads / artifacts (exact name from later implementation steps).
S3_BUCKET="your-scripturelm-bucket"
# Embedding model identifier for Bedrock (set to the model you enable in your account).
BEDROCK_EMBEDDING_MODEL_ID="amazon.titan-embed-text-v2:0"

# Credentials: use static keys for local dev, or AWS_PROFILE with shared config/credentials,
# or omit keys when running on AWS with an IAM role (App Runner, Lambda, etc.).
# For SSO / named profiles locally: `export AWS_PROFILE=your-profile` (PowerShell: `$env:AWS_PROFILE='...'`)
# and ensure the SDK loads config (`AWS_SDK_LOAD_CONFIG=1`) if you rely on config file settings.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_PROFILE=""

# --- LLM (Anthropic; server-side only) ---
ANTHROPIC_API_KEY=""

# --- Auth (Auth.js / NextAuth-style) ---
# Single secret for signing sessions/JWTs. Prefer AUTH_SECRET; NEXTAUTH_SECRET is still accepted.
AUTH_SECRET=""
# NEXTAUTH_SECRET=""
# Base URL for Auth.js (local dev). Production: your deployed origin.
AUTH_URL="http://localhost:3000"

# Optional: bcrypt password for prisma seed user (see SEED_USER_EMAIL in prisma/seed.ts).
# SEED_USER_PASSWORD=""

# Optional OAuth (uncomment when wired in auth steps).
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- Operator / ingest HMAC or shared secret for protected internal routes ---
OPERATOR_INGEST_SECRET=""

# --- Optional async pipeline ---
# SQS_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/123456789012/your-queue"
